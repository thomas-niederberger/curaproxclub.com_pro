# API Router
# Route all /api/* requests to api.php which proxies to the actual API folder
RewriteEngine On
RewriteBase /

# Route API requests to the API router
RewriteRule ^api/([a-zA-Z0-9_\-]+\.php)$ api.php [L,QSA]

# Prevent direct access to api.php
RewriteCond %{REQUEST_URI} ^/api\.php$
RewriteRule ^ - [F,L]
